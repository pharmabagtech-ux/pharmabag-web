{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@pharmabag/api-client": ["../../packages/api-client/src"],
      "@pharmabag/api-client/*": ["../../packages/api-client/src/*"],
      "@pharmabag/utils": ["../../packages/utils/src"],
      "@pharmabag/utils/*": ["../../packages/utils/src/*"]
    },
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
